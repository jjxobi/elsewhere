              <calculation class='tableau' formula='[city] + &quot; has a safety score of &quot; + STR(ROUND([safety_index],0)) + &#13;&#10;IF [safety_index] &gt; { FIXED : AVG(IF [city]=[Parameters].[Parameter 0305409982001153] THEN [safety_index] END) } &#13;&#10;THEN &quot;, better than your home city&quot; ELSE &quot;, worse than your home city&quot; END' />
            </column>
            <column caption='Cost callout' datatype='string' name='[Calculation_1525595142385690]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[city] + &quot; has a cost of living index of &quot; + STR(ROUND([cost_of_living_index],0)) + &#13;&#10;IF [cost_of_living_index] &lt; { FIXED : AVG(IF [city]=[Parameters].[Parameter 0305409982001153] THEN [cost_of_living_index] END) } &#13;&#10;THEN &quot;, cheaper than your home city&quot; ELSE &quot;, more expensive than your home city&quot; END' />
            </column>
            <column caption='Healthcare Callout Text' datatype='string' name='[Calculation_1525595142516763]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[city] + &quot; has a healthcare score of &quot; + STR(ROUND([healthcare_index],0)) + &#13;&#10;IF [healthcare_index] &gt; { FIXED : AVG(IF [city]=[Parameters].[Parameter 0305409982001153] THEN [healthcare_index] END) } &#13;&#10;THEN &quot;, better than your home city&quot; ELSE &quot;, worse than your home city&quot; END' />
            </column>
            <column caption='Climate Callout Text' datatype='string' name='[Calculation_1525595142721564]' role='dimension' type='nominal'>
