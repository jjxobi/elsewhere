    <dashboard enable-sort-zone-taborder='true' name='Title'>
      <repository-location derived-from='https://public.tableau.com/workbooks/ElsewhereGlobalLifestyleCostIntelligenceDashboard/Title?rev=' id='131829787' path='/workbooks/ElsewhereGlobalLifestyleCostIntelligenceDashboard' revision='' />
      <style>
        <style-rule element='table'>
          <format attr='background-color' value='#1a1a2e' />
        </style-rule>
      </style>
      <size maxheight='800' maxwidth='1000' minheight='800' minwidth='1000' />
      <zones>
        <zone forceUpdate='true' h='21750' id='3' type-v2='text' w='46200' x='25800' y='11250'>
          <formatted-text>
            <run bold='true' fontcolor='#e8c547' fontsize='48'>Elsewhere</run>
          </formatted-text>
        </zone>
        <zone h='4500' id='4' type-v2='text' w='42700' x='27400' y='27000'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#c0c0c0' fontsize='14'>A global lifestyle &amp; cost intelligence dashboard</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='9750' id='5' type-v2='text' w='48900' x='25100' y='32000'>
          <formatted-text>
            <run fontcolor='#f5f5f5' fontsize='14' italic='true'>Given your salary and priorities — where in the world could you live better, cheaper, or both?</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='36000' id='6' type-v2='text' w='54900' x='22000' y='42125'>
          <formatted-text>
            <run fontcolor='#e8c547' fontsize='11'>How to use this dashboard</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontsize='11'>Set your salary and home city using the controls at the top of any page. Every chart recalculates live around your specific situation.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#e8c547' fontsize='11'>World Map</run>
            <run fontalignment='0' fontcolor='#ffffff' fontsize='11'>: explore how every city compares to your home city at a glance</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#e8c547' fontsize='11'>Shortlist:</run>
            <run fontalignment='0' fontcolor='#ffffff' fontsize='11'> see your top-ranked matches, and exactly why they rank where they do</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#e8c547' fontsize='11'>City Deep Dive</run>
            <run fontalignment='0' fontcolor='#ffffff' fontsize='11'>: compare any two cities head-to-head in detail</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#e8c547' fontsize='11'>Seoul Spotlight</run>
            <run fontalignment='0' fontcolor='#ffffff' fontsize='11'>: a personal case study (this is the city I&apos;m actually considering)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#e8c547' fontsize='11'>Data Story</run>
            <run fontalignment='0' fontcolor='#ffffff' fontsize='11'>: five findings from analyzing this dataset</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='3750' id='7' type-v2='text' w='70100' x='14000' y='95000'>
          <formatted-text>
            <run fontcolor='#666666' fontname='Calibri'>Built by Jesse O&apos;Brien · Data: Numbeo, World Bank, Wikipedia/Speedtest · github.com/jjxobi/elsewhere</run>
          </formatted-text>
        </zone>
      </zones>
