            <column caption='Home City COL Index' datatype='real' name='[Calculation_0305409982980098]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG(IF [city] = [Parameters].[Parameter 0305409982001153] THEN [cost_of_living_index] END) }' />
            </column>
            <column caption='Safety Call Out Text' datatype='string' name='[Calculation_1525594240745486]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[city] + &quot; has a safety score of &quot; + STR(ROUND([safety_index],0)) + &#13;&#10;IF [safety_index] &gt; { FIXED : AVG(IF [city]=[Parameters].[Parameter 0305409982001153] THEN [safety_index] END) } &#13;&#10;THEN &quot;, better than your home city&quot; ELSE &quot;, worse than your home city&quot; END' />
            </column>
            <column caption='Seoul Internet Rank Text' datatype='string' name='[Calculation_1525594395951119]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;Internet speed: &quot; + STR(ROUND([internet_speed_mbps],0)) + &quot; Mbps&quot;' />
            </column>
            <column caption='Cost of living Call Out Text' datatype='string' name='[Calculation_1525594396610576]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;Cost of living is &quot; + &#13;&#10;STR(ROUND(ABS(100 * ({ FIXED : AVG(IF [city]=&quot;Seoul&quot; THEN [cost_of_living_index] END) } - [Calculation_0305409982980098]) / [Calculation_0305409982980098]), 0)) + &#13;&#10;&quot;% &quot; + &#13;&#10;IF { FIXED : AVG(IF [city]=&quot;Seoul&quot; THEN [cost_of_living_index] END) } &lt; [Calculation_0305409982980098] &#13;&#10;THEN &quot;lower&quot; ELSE &quot;higher&quot; END + &#13;&#10;&quot; than your home city&quot;' />
            </column>
            <column caption='City' datatype='string' name='[city]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
            <column caption='Cost Of Living Index' datatype='real' name='[cost_of_living_index]' role='measure' type='quantitative' />
            <column caption='Internet Speed Mbps' datatype='real' name='[internet_speed_mbps]' role='measure' type='quantitative' />
