    <worksheet name='Finding 4 - Purchasing Power Illusion'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#ffffff' fontsize='12'>The purchasing power illusion</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='master_data' name='federated.092gf5r0te43n11g6b2cn0ttmq8e' />
          </datasources>
          <datasource-dependencies datasource='federated.092gf5r0te43n11g6b2cn0ttmq8e'>
            <column caption='PP Highlight' datatype='string' name='[Calculation_1525594690080785]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [city] = &quot;Hyderabad&quot; OR [city] = &quot;Pune&quot; OR [city] = &quot;Noida&quot; OR &#13;&#10;   [city] = &quot;Chengdu&quot; OR [city] = &quot;Nanjing&quot; OR [city] = &quot;Xi&apos;an&quot;&#13;&#10;THEN &quot;Highlighted&quot; ELSE &quot;Other&quot; END' />
            </column>
            <column caption='PPP Residual' datatype='real' name='[Calculation_1525594940874771]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[local_purchasing_power_index] - (1.383934 * [cost_of_living_index] + 14.598751)' />
            </column>
            <column caption='City' datatype='string' name='[city]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
            <column caption='Cost Of Living Index' datatype='real' name='[cost_of_living_index]' role='measure' type='quantitative' />
            <column caption='Country' datatype='string' name='[country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column caption='Local Purchasing Power Index' datatype='real' name='[local_purchasing_power_index]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1525594690080785]' derivation='None' name='[none:Calculation_1525594690080785:nk]' pivot='key' type='nominal' />
            <column-instance column='[city]' derivation='None' name='[none:city:nk]' pivot='key' type='nominal' />
            <column-instance column='[country]' derivation='None' name='[none:country:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1525594940874771]' derivation='Sum' name='[sum:Calculation_1525594940874771:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.092gf5r0te43n11g6b2cn0ttmq8e].[none:city:nk]'>
            <groupfilter count='15' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='SUM([Calculation_1525594940874771])' function='order' user:ui-marker='order'>
                <groupfilter expression='SUM([cost_of_living_index]) &lt; 56.' function='filter' user:ui-filter-by-field='true' user:ui-marker='filter-by'>
                  <groupfilter function='level-members' level='[none:city:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
                </groupfilter>
              </groupfilter>
            </groupfilter>
          </filter>
