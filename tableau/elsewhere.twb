            <column-instance column='[Calculation_1525594395951119]' derivation='None' name='[none:Calculation_1525594395951119:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1525594396610576]' derivation='None' name='[none:Calculation_1525594396610576:nk]' pivot='key' type='nominal' />
            <column-instance column='[city]' derivation='None' name='[none:city:nk]' pivot='key' type='nominal' />
            <column caption='Safety Index' datatype='real' name='[safety_index]' role='measure' type='quantitative' />
