    <worksheet name='Seoul KPI Strip'>
      <table>
        <view>
          <datasources>
            <datasource caption='master_data' name='federated.092gf5r0te43n11g6b2cn0ttmq8e' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Salary Parameter' datatype='real' name='[Parameter 0305409981657088]' param-domain-type='any' role='measure' type='quantitative' value='120000.'>
              <calculation class='tableau' formula='120000.' />
            </column>
            <column caption='Home City Parameter' datatype='string' name='[Parameter 0305409982001153]' param-domain-type='list' role='measure' type='nominal' value='&quot;Auckland&quot;'>
              <calculation class='tableau' formula='&quot;Auckland&quot;' />
            </column>
            <column caption='Compare City Parameter' datatype='string' name='[Parameter 1525593886654467]' param-domain-type='list' role='measure' type='nominal' value='&quot;Seoul&quot;'>
              <calculation class='tableau' formula='&quot;Seoul&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.092gf5r0te43n11g6b2cn0ttmq8e'>
            <column caption='Home City COL Index' datatype='real' name='[Calculation_0305409982980098]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG(IF [city] = [Parameters].[Parameter 0305409982001153] THEN [cost_of_living_index] END) }' />
            </column>
            <column caption='Required Salary' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Calculation_0305409983369219]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Parameters].[Parameter 0305409981657088] * ([cost_of_living_index] / [Calculation_0305409982980098])' />
            </column>
            <column caption='Salary Delta Pct' datatype='real' default-format='*+0.00%;-0.00%' name='[Calculation_0305409983639557]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_0305409983369219] - [Parameters].[Parameter 0305409981657088]) / [Parameters].[Parameter 0305409981657088]' />
            </column>
            <column caption='Composite Score' datatype='real' name='[Calculation_1525593879588864]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;  (8 * (1 - ([cost_of_living_index] / 200))) +&#13;&#10;  (7 * [safety_index] / 100) +&#13;&#10;  (6 * [healthcare_index] / 100) +&#13;&#10;  (7 * ([internet_speed_mbps] / 200)) +&#13;&#10;  (5 * (1 - [pollution_index] / 100)) +&#13;&#10;  (6 * [quality_of_life_index] / 200)&#13;&#10;) / 39 * 100' />
            </column>
            <column caption='Home City Composite Score' datatype='real' name='[Calculation_1525593881956353]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG(IF [city] = [Parameters].[Parameter 0305409982001153] THEN [Calculation_1525593879588864] END) }' />
            </column>
            <column caption='Compare City Composite Score' datatype='real' name='[Calculation_1525594018357255]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG(IF [city] = [Parameters].[Parameter 1525593886654467] THEN [Calculation_1525593879588864] END) }' />
            </column>
            <column caption='Safety vs Home' datatype='real' name='[Calculation_1525594080804873]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[safety_index] - { FIXED : AVG(IF [city] = [Parameters].[Parameter 0305409982001153] THEN [safety_index] END) }' />
            </column>
            <column caption='City' datatype='string' name='[city]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
            <column caption='Cost Of Living Index' datatype='real' name='[cost_of_living_index]' role='measure' type='quantitative' />
            <column caption='Healthcare Index' datatype='real' name='[healthcare_index]' role='measure' type='quantitative' />
            <column caption='Internet Speed Mbps' datatype='real' name='[internet_speed_mbps]' role='measure' type='quantitative' />
            <column-instance column='[city]' derivation='None' name='[none:city:nk]' pivot='key' type='nominal' />
            <column caption='Pollution Index' datatype='real' name='[pollution_index]' role='measure' type='quantitative' />
            <column caption='Quality Of Life Index' datatype='real' name='[quality_of_life_index]' role='measure' type='quantitative' />
            <column caption='Safety Index' datatype='real' name='[safety_index]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0305409983369219]' derivation='Sum' name='[sum:Calculation_0305409983369219:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0305409983639557]' derivation='Sum' name='[sum:Calculation_0305409983639557:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1525593881956353]' derivation='Sum' name='[sum:Calculation_1525593881956353:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1525594018357255]' derivation='Sum' name='[sum:Calculation_1525594018357255:qk]' pivot='key' type='quantitative' />
