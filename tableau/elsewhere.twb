      <aliases enabled='yes' />
      <column caption='Home City COL Index' datatype='real' name='[Calculation_0305409982980098]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [city] = [Parameters].[Parameter 0305409982001153] THEN [cost_of_living_index] END) }' />
      </column>
      <column caption='Required Salary' datatype='real' name='[Calculation_0305409983369219]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 0305409981657088] * ([cost_of_living_index] / [Calculation_0305409982980098])' />
      </column>
      <column caption='Salary Delta' datatype='real' name='[Calculation_0305409983426564]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0305409983369219] - [Parameters].[Parameter 0305409981657088]' />
      </column>
      <column caption='Salary Delta Pct' datatype='real' name='[Calculation_0305409983639557]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0305409983369219] - [Parameters].[Parameter 0305409981657088]) / [Parameters].[Parameter 0305409981657088]' />
      </column>
      <column caption='Better or Worse' datatype='string' name='[Calculation_0305409983737862]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [city] = [Parameters].[Parameter 0305409982001153] THEN &quot;Home City&quot;&#13;&#10;ELSEIF [Calculation_0305409983369219] &lt; [Parameters].[Parameter 0305409981657088] THEN &quot;Better Off&quot;&#13;&#10;ELSEIF [Calculation_0305409983369219] &gt; [Parameters].[Parameter 0305409981657088] * 1.05 THEN &quot;Worse Off&quot;&#13;&#10;ELSE &quot;Similar&quot;&#13;&#10;END' />
      </column>
      <column caption='Composite Score' datatype='real' name='[Calculation_1525593879588864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;  (8 * (1 - ([cost_of_living_index] / 200))) +&#13;&#10;  (7 * [safety_index] / 100) +&#13;&#10;  (6 * [healthcare_index] / 100) +&#13;&#10;  (7 * ([internet_speed_mbps] / 200)) +&#13;&#10;  (5 * (1 - [pollution_index] / 100)) +&#13;&#10;  (6 * [quality_of_life_index] / 200)&#13;&#10;) / 39 * 100' />
      </column>
      <column caption='Home City Composite Score' datatype='real' name='[Calculation_1525593881956353]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [city] = [Parameters].[Parameter 0305409982001153] THEN [Calculation_1525593879588864] END) }' />
      </column>
      <column caption='Dimension Order' datatype='real' name='[Calculation_1525593974632452]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Measure Names]&#13;&#10;WHEN &quot;Cost Of Living Index&quot; THEN 1&#13;&#10;WHEN &quot;Safety Index&quot; THEN 2&#13;&#10;WHEN &quot;Healthcare Index&quot; THEN 3&#13;&#10;WHEN &quot;Internet Speed Mbps&quot; THEN 4&#13;&#10;WHEN &quot;Pollution Index&quot; THEN 5&#13;&#10;WHEN &quot;Quality Of Life Index&quot; THEN 6&#13;&#10;END' />
      </column>
      <column caption='City Role' datatype='string' name='[Calculation_1525594017497094]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [city] = [Parameters].[Parameter 0305409982001153] THEN &quot;Home City&quot;&#13;&#10;ELSEIF [city] = [Parameters].[Parameter 1525593886654467] THEN &quot;Compare City&quot;&#13;&#10;END' />
      </column>
      <column caption='Compare City Composite Score' datatype='real' name='[Calculation_1525594018357255]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [city] = [Parameters].[Parameter 1525593886654467] THEN [Calculation_1525593879588864] END) }' />
      </column>
      <column caption='Cost vs Home' datatype='real' name='[Calculation_1525594080706568]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0305409982980098] - [cost_of_living_index]' />
      </column>
      <column caption='Safety vs Home' datatype='real' name='[Calculation_1525594080804873]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[safety_index] - { FIXED : AVG(IF [city] = [Parameters].[Parameter 0305409982001153] THEN [safety_index] END) }' />
      </column>
      <column caption='Healthcare vs Home' datatype='real' name='[Calculation_1525594080870410]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[healthcare_index] - { FIXED : AVG(IF [city] = [Parameters].[Parameter 0305409982001153] THEN [healthcare_index] END) }' />
      </column>
      <column caption='Internet vs Home' datatype='real' name='[Calculation_1525594080931851]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[internet_speed_mbps] - { FIXED : AVG(IF [city] = [Parameters].[Parameter 0305409982001153] THEN [internet_speed_mbps] END) }' />
      </column>
      <column caption='Climate vs Home' datatype='real' name='[Calculation_1525594080997388]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [city] = [Parameters].[Parameter 0305409982001153] THEN [pollution_index] END) } - [pollution_index]' />
      </column>
      <column caption='Culture vs Home' datatype='real' name='[Calculation_1525594081054733]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[quality_of_life_index] - { FIXED : AVG(IF [city] = [Parameters].[Parameter 0305409982001153] THEN [quality_of_life_index] END) }' />
      </column>
      <column caption='Safety Call Out Text' datatype='string' name='[Calculation_1525594240745486]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[city] + &quot; has a safety score of &quot; + STR(ROUND([safety_index],0)) + &#13;&#10;IF [safety_index] &gt; { FIXED : AVG(IF [city]=[Parameters].[Parameter 0305409982001153] THEN [safety_index] END) } &#13;&#10;THEN &quot;, better than your home city&quot; ELSE &quot;, worse than your home city&quot; END' />
      </column>
      <column caption='Seoul Internet Rank Text' datatype='string' name='[Calculation_1525594395951119]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Internet speed: &quot; + STR(ROUND([internet_speed_mbps],0)) + &quot; Mbps&quot;' />
      </column>
      <column caption='Cost of living Call Out Text' datatype='string' name='[Calculation_1525594396610576]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Cost of living is &quot; + &#13;&#10;STR(ROUND(ABS(100 * ({ FIXED : AVG(IF [city]=&quot;Seoul&quot; THEN [cost_of_living_index] END) } - [Calculation_0305409982980098]) / [Calculation_0305409982980098]), 0)) + &#13;&#10;&quot;% &quot; + &#13;&#10;IF { FIXED : AVG(IF [city]=&quot;Seoul&quot; THEN [cost_of_living_index] END) } &lt; [Calculation_0305409982980098] &#13;&#10;THEN &quot;lower&quot; ELSE &quot;higher&quot; END + &#13;&#10;&quot; than your home city&quot;' />
      </column>
